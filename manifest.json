{
  "manifest_version": 3,
  "name": "LabuIA - Empleos con IA",
  "version": "1.0",
  "description": "Buscá empleos en Argentina y postulate con IA",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.computrabajo.com.ar/*",
    "https://*.zonajobs.com.ar/*",
    "https://*.bumeran.com.ar/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
